{
  "name": "karaoke-queue",
  "version": "1.0.0",
  "description": "Lightweight karaoke queue — a YouTube wrapper you can queue to by scanning a QR code.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "build": "vite build",
    "dev:client": "vite",
    "dev": "concurrently -k -n server,client \"node server.js\" \"vite\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "sortablejs": "^1.15.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
